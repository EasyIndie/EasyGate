c3lzLmV4aXQoMSkK
EOF_B64
  chmod +x "$target"
}

# 获取 service helper 路径（优先运行时，fallback 源码）
_service_helper() {
  local helper="${EASYGATE_HOME}/lib/service-helper.py"
  if [[ -f "$helper" ]]; then
    printf '%s' "$helper"
    return
  fi
  if [[ -f "${SCRIPT_DIR:-${0%/*}}/service-helper.py" ]]; then
    printf '%s' "${SCRIPT_DIR:-${0%/*}}/service-helper.py"
    return
  fi
  # 内嵌 base64 还未被提取过，现在提取
  install_service_helper
  if [[ -f "$helper" ]]; then
    printf '%s' "$helper"
    return
  fi
  return 1
}

write_native_demo_server() {
  mkdir -p "${EASYGATE_HOME}/lib"
  cat > "${EASYGATE_HOME}/lib/native-demo-server.py" <<'EOF_PY'
#!/usr/bin/env python3
import argparse
import socket
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        body = "\n".join([
            f"Hostname: {socket.gethostname()}",
            "IP: 127.0.0.1",
            f"RemoteAddr: {self.client_address[0]}:{self.client_address[1]}",
            f"Host: {self.headers.get('Host', '')}",
            f"Path: {self.path}",
            "",
        ]).encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, _format, *_args):
        return

def main():
    parser = argparse.ArgumentParser(description="EasyGate native demo HTTP server")
    parser.add_argument("--port", type=int, required=True)
    args = parser.parse_args()
    ThreadingHTTPServer(("127.0.0.1", args.port), Handler).serve_forever()

if __name__ == "__main__":
    main()
EOF_PY
  chmod +x "${EASYGATE_HOME}/lib/native-demo-server.py"
}

deploy_native() {
  local base_domain="" tunnel_name="easygate-home" dashboard_host="" traefik_http_port="18080"
  local native_api_port="${EASYGATE_NATIVE_API_PORT:-19080}" native_test_api_port="${EASYGATE_NATIVE_TEST_API_PORT:-19081}"
  local route_dns=true start_demo=false local_only=false install_cloudflared=true install_traefik=true
  local _started_pids=()

  # Clean up any started processes if the deployment is interrupted.
  _native_interrupt_cleanup() {
    local f
    for f in "${_started_pids[@]}"; do
      stop_pid_file "$f"
    done
  }
  trap '_native_interrupt_cleanup' INT TERM

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --domain) shift; base_domain="${1:-}" ;;
      --tunnel) shift; tunnel_name="${1:-}" ;;
      --dashboard) shift; dashboard_host="${1:-}" ;;
      --port) shift; traefik_http_port="${1:-}" ;;
      --api-port) shift; native_api_port="${1:-}" ;;
      --test-api-port) shift; native_test_api_port="${1:-}" ;;
      --skip-route) route_dns=false ;;
      --demo) start_demo=true ;;
      --local-only) local_only=true; route_dns=false ;;
      --no-install-cloudflared) install_cloudflared=false ;;
      --no-install-traefik) install_traefik=false ;;
      -h|--help) usage; exit 0 ;;
      *) error "未知参数：$1"; usage; exit 1 ;;
    esac
    shift
  done

  assert_no_compose_deployment
  install_traefik "$install_traefik"
  if [[ "$local_only" != true ]]; then
    install_cloudflared "$install_cloudflared"
  fi

  if [[ -z "$base_domain" ]]; then
    base_domain="$(prompt_default "请输入主域名" "example.com")"
  fi
  if [[ "$local_only" != true ]]; then
    validate_domain "$base_domain" || exit 1
  fi
  validate_tunnel_name "$tunnel_name" || exit 1
  validate_port "$traefik_http_port" "TRAEFIK_HTTP_PORT" || exit 1
  validate_port "$native_api_port" "NATIVE_API_PORT" || exit 1
  validate_port "$native_test_api_port" "NATIVE_TEST_API_PORT" || exit 1
  if [[ -z "$dashboard_host" ]]; then
    dashboard_host="traefik.${base_domain}"
  fi

  mkdir -p "${EASYGATE_HOME}/native/dynamic" "${EASYGATE_HOME}/run" "${EASYGATE_HOME}/logs" "${EASYGATE_HOME}/cloudflared"

  cat > "${EASYGATE_HOME}/native/.env" <<EOF_ENV
BASE_DOMAIN=${base_domain}
TRAEFIK_HTTP_PORT=${traefik_http_port}
TRAEFIK_DASHBOARD_HOST=${dashboard_host}
EASYGATE_DEPLOY_MODE=native
EASYGATE_NATIVE_API_PORT=${native_api_port}
EASYGATE_NATIVE_TEST_API_PORT=${native_test_api_port}
EASYGATE_HOME=${EASYGATE_HOME}
EOF_ENV

  cat > "${EASYGATE_HOME}/native/traefik.yml" <<EOF_TRAEFIK
global:
  checkNewVersion: false
  sendAnonymousUsage: false

api:
  dashboard: true

entryPoints:
  web:
    address: "127.0.0.1:${traefik_http_port}"

providers:
  file:
    directory: "${EASYGATE_HOME}/native/dynamic"
    watch: true
EOF_TRAEFIK

  cat > "${EASYGATE_HOME}/native/dynamic/services.yml" <<EOF_DYNAMIC
http:
  routers:
    traefik-dashboard:
      rule: Host(\`${dashboard_host}\`)
      entryPoints:
        - web
      service: api@internal
EOF_DYNAMIC

  if [[ "$start_demo" == true ]]; then
    cat >> "${EASYGATE_HOME}/native/dynamic/services.yml" <<EOF_DEMO
    demo-api:
      rule: Host(\`api.${base_domain}\`)
      entryPoints:
        - web
      service: demo-api
    demo-test-api:
      rule: Host(\`test-api.${base_domain}\`)
      entryPoints:
        - web
      service: demo-test-api

  services:
    demo-api:
      loadBalancer:
        servers:
          - url: http://127.0.0.1:${native_api_port}
    demo-test-api:
      loadBalancer:
        servers:
          - url: http://127.0.0.1:${native_test_api_port}
EOF_DEMO
  fi

  if [[ "$local_only" != true ]]; then
    info "确认 cloudflared 登录状态"
    if [[ ! -f "${CLOUDFLARED_HOME}/cert.pem" ]]; then
      warn "未找到 ${CLOUDFLARED_HOME}/cert.pem，将执行 cloudflared tunnel login"
      cloudflared tunnel login
    else
      info "已找到 cloudflared 登录凭据"
    fi

    prepare_tunnel_credentials "$tunnel_name"

    if [[ "$route_dns" == true ]]; then
      info "创建通配 DNS 路由：*.${base_domain}"
      local route_output
      route_output="$(cloudflared tunnel route dns "$tunnel_name" "*.${base_domain}" 2>&1)" || true
      if echo "$route_output" | grep -q "already exists"; then
        warn "DNS 通配路由已存在。若子域名无法访问，请到 Cloudflare DNS 检查是否有独立子域名记录（如 traefik.${base_domain}、api.${base_domain}）覆盖了通配符。"
      elif ! echo "$route_output" | grep -qE "Added|created"; then
        warn "自动创建 DNS 路由失败：${route_output}"
      fi
    else
      warn "已跳过 DNS 路由创建"
    fi

    cat > "${EASYGATE_HOME}/cloudflared/config.native.yml" <<EOF_CLOUDFLARED
tunnel: ${tunnel_name}
credentials-file: ${EASYGATE_HOME}/cloudflared/${tunnel_name}.json
ha-connections: 2
loglevel: warn

ingress:
  - hostname: "*.${base_domain}"
    service: http://127.0.0.1:${traefik_http_port}
  - service: http_status:404
EOF_CLOUDFLARED
  fi

  if [[ "$start_demo" == true ]]; then
    local python_bin
    python_bin="$(find_python)" || { error "原生 demo 需要 python3 或 python"; exit 1; }
    write_native_demo_server
    start_process "native-demo-api" "$python_bin" "${EASYGATE_HOME}/lib/native-demo-server.py" --port "$native_api_port"
    _started_pids+=("${EASYGATE_HOME}/run/native-demo-api.pid")
    start_process "native-demo-test-api" "$python_bin" "${EASYGATE_HOME}/lib/native-demo-server.py" --port "$native_test_api_port"
    _started_pids+=("${EASYGATE_HOME}/run/native-demo-test-api.pid")
  fi

  # 检查端口是否已被占用（如手动启动的 Traefik 实例）
  check_port_available "$traefik_http_port" "Traefik 端口" || exit 1

  # 注册系统服务并启动（系统服务管理器负责进程生命周期）
  case "$(uname -s)" in
    Linux)
      register_systemd "native-traefik" "$(command -v traefik)" \
        "--configFile=${EASYGATE_HOME}/native/traefik.yml" \
        "EasyGate Traefik" "network.target"
      if [[ "$local_only" != true ]]; then
        register_systemd "native-cloudflared" "$(command -v cloudflared)" \
          "tunnel --config ${EASYGATE_HOME}/cloudflared/config.native.yml run" \
          "EasyGate Cloudflared Tunnel" "network.target"
      fi
      ;;
    Darwin)
      register_launchd "native-traefik" "$(command -v traefik)" \
        "--configFile=${EASYGATE_HOME}/native/traefik.yml"
      if [[ "$local_only" != true ]]; then
        register_launchd "native-cloudflared" "$(command -v cloudflared)" \
          "tunnel --config ${EASYGATE_HOME}/cloudflared/config.native.yml run"
      fi
      ;;
    *)
      # 无系统服务管理器时 fallback 到 nohup
      start_process "native-traefik" "$(command -v traefik)" --configFile="${EASYGATE_HOME}/native/traefik.yml"
      _started_pids+=("${EASYGATE_HOME}/run/native-traefik.pid")
      if [[ "${EASYGATE_CI:-}" != "true" ]]; then
        check_process_started "native-traefik" || exit 1
      fi
      if [[ "$local_only" != true ]]; then
        start_process "native-cloudflared" "$(command -v cloudflared)" tunnel --config "${EASYGATE_HOME}/cloudflared/config.native.yml" run
        _started_pids+=("${EASYGATE_HOME}/run/native-cloudflared.pid")
        if [[ "${EASYGATE_CI:-}" != "true" ]]; then
          check_process_started "native-cloudflared" || true
        fi
      fi
      ;;
  esac

  # Deployment completed successfully — disarm interrupt trap.
  trap - INT TERM

  write_mode_file "native"
  install_service_helper
  register_logrotate_timer 2>/dev/null || true

  info "原生部署完成"
  printf '\n后续检查：\n'
  printf '  easygate logs\n'
  printf '  运行时目录：%s\n' "$EASYGATE_HOME"
}

# ── Service management helpers ───────────────────────────────────────

# 检测当前部署模式：读取 .mode 文件或推断
detect_mode() {
  if [[ -f "${EASYGATE_HOME}/.mode" ]]; then
    cat "${EASYGATE_HOME}/.mode"
    return
  fi
  # 从 PID 文件推断原生模式，从 compose 文件推断 Docker 模式
  if [[ -f "${EASYGATE_HOME}/run/native-traefik.pid" ]] || [[ -f "${EASYGATE_HOME}/run/native-cloudflared.pid" ]]; then
    echo "native"
    return
  fi
  if [[ -f "$COMPOSE_FILE" && -f "$COMPOSE_ENV" ]]; then
    echo "compose"
    return
  fi
  echo ""
}

# 写入部署模式标记文件，供 detect_mode 读取
write_mode_file() {
  local mode="$1"
  printf '%s\n' "$mode" > "${EASYGATE_HOME}/.mode"
}

start_services() {
  local mode
  mode="$(detect_mode)"
  case "$mode" in
    compose)
      require_command docker || exit 1
      compose start "$@"
      info "服务已启动"
      ;;
    native) start_native_services ;;
    *) error "未找到已部署的服务，请先执行 easygate deploy" ; return 1 ;;
  esac
}

stop_services() {
  local mode
  mode="$(detect_mode)"
  case "$mode" in
    compose)
      require_command docker || exit 1
      compose stop "$@"
      info "服务已停止，配置和凭据已保留"
      ;;
    native) stop_native_services ;;
    *) error "未找到已部署的服务，请先执行 easygate deploy" ; return 1 ;;
  esac
}

restart_services() {
  local mode
  mode="$(detect_mode)"
  case "$mode" in
    compose)
      require_command docker || exit 1
      compose restart "$@"
      info "服务已重启"
      ;;
    native)
      stop_native_services
      start_native_services
      info "服务已重启"
      ;;
    *) error "未找到已部署的服务，请先执行 easygate deploy" ; return 1 ;;
  esac
}

# 日志轮转：单文件超过 max_size (默认 10MB) 时归档
rotate_logs() {
  local max_size="${EASYGATE_LOG_MAX_SIZE:-10485760}"  # 10MB
  local keep="${EASYGATE_LOG_KEEP:-5}"
  local log_dir="${EASYGATE_HOME}/logs"
  [[ -d "$log_dir" ]] || return 0
  local log_file
  for log_file in "$log_dir"/*.log; do
    [[ -f "$log_file" ]] || continue
    local size
    size="$(stat -f%z "$log_file" 2>/dev/null || stat -c%s "$log_file" 2>/dev/null || echo 0)"
    if [[ "$size" -gt "$max_size" ]]; then
      # 轮转：删除最旧的，依次移动
      local i
      rm -f "${log_file}.${keep}"
      for ((i = keep - 1; i >= 1; i--)); do
        [[ -f "${log_file}.${i}" ]] && mv "${log_file}.${i}" "${log_file}.$((i + 1))"
      done
      mv "$log_file" "${log_file}.1"
      touch "$log_file"
      info "已轮转日志：${log_file##*/}"
    fi
  done
}

# 注册日志轮转定时任务
register_logrotate_timer() {
  case "$(uname -s)" in
    Darwin)
      local plist="${HOME}/Library/LaunchAgents/com.easygate.logrotate.plist"
      mkdir -p "${HOME}/Library/LaunchAgents"
      cat > "$plist" <<'EOF_PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.easygate.logrotate</string>
    <key>ProgramArguments</key>
    <array>
        <string>EASYGATE_BIN</string>
        <string>logs</string>
        <string>--rotate</string>
    </array>
    <key>StartInterval</key>
    <integer>86400</integer>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
EOF_PLIST
      sed -i '' "s|EASYGATE_BIN|${EASYGATE_HOME}/bin/easygate|" "$plist"
      launchctl unload "$plist" >/dev/null 2>&1 || true
      launchctl load "$plist" >/dev/null 2>&1 || true
      ;;
    Linux)
      mkdir -p "${HOME}/.config/systemd/user"
      cat > "${HOME}/.config/systemd/user/easygate-logrotate.service" <<EOF_UNIT
[Unit]
Description=EasyGate Log Rotation

[Service]
Type=oneshot
ExecStart=${EASYGATE_HOME}/bin/easygate logs --rotate
EOF_UNIT
      cat > "${HOME}/.config/systemd/user/easygate-logrotate.timer" <<EOF_TIMER
[Unit]
Description=EasyGate Daily Log Rotation

[Timer]
OnCalendar=daily
Persistent=true

[Install]
WantedBy=timers.target
EOF_TIMER
      systemctl --user daemon-reload >/dev/null 2>&1 || true
      systemctl --user enable --now easygate-logrotate.timer >/dev/null 2>&1 || true
      ;;
  esac
}

start_native_services() {
  local env_file="${EASYGATE_HOME}/native/.env"
  [[ -f "$env_file" ]] || { error "未找到原生模式环境文件：${env_file}"; return 1; }
  # shellcheck source=/dev/null
  source "$env_file"

  # 优先使用系统服务管理器启动
  case "$(uname -s)" in
    Darwin)
      local traefik_plist="${HOME}/Library/LaunchAgents/com.easygate.native-traefik.plist"
      local cloudflared_plist="${HOME}/Library/LaunchAgents/com.easygate.native-cloudflared.plist"
      if [[ -f "$traefik_plist" ]] && command -v launchctl >/dev/null 2>&1; then
        info "通过 launchd 启动服务"
        launchctl load "$traefik_plist" >/dev/null 2>&1 || true
        if [[ "${EASYGATE_DEPLOY_MODE:-}" != "local-only" ]]; then
          launchctl load "$cloudflared_plist" >/dev/null 2>&1 || true
        fi
        return
      fi
      ;;
    Linux)
      local traefik_unit="${HOME}/.config/systemd/user/easygate-traefik.service"
      if [[ -f "$traefik_unit" ]] && command -v systemctl >/dev/null 2>&1; then
        info "通过 systemd 启动服务"
        systemctl --user start "easygate-traefik.service" >/dev/null 2>&1 || true
        if [[ "${EASYGATE_DEPLOY_MODE:-}" != "local-only" ]]; then
          systemctl --user start "easygate-cloudflared.service" >/dev/null 2>&1 || true
        fi
        return
      fi
      ;;
  esac

  # 无系统服务时 fallback 到 nohup
  local traefik_bin="${EASYGATE_HOME}/bin/traefik"
  local cloudflared_bin="${EASYGATE_HOME}/bin/cloudflared"
  command -v traefik >/dev/null 2>&1 && traefik_bin="$(command -v traefik)"
  command -v cloudflared >/dev/null 2>&1 && cloudflared_bin="$(command -v cloudflared)"

  check_port_available "${TRAEFIK_HTTP_PORT:-18080}" "Traefik 端口" || return 1
  start_process "native-traefik" "$traefik_bin" --configFile="${EASYGATE_HOME}/native/traefik.yml"
  if [[ "${EASYGATE_DEPLOY_MODE:-}" != "local-only" ]]; then
    start_process "native-cloudflared" "$cloudflared_bin" tunnel --config "${EASYGATE_HOME}/cloudflared/config.native.yml" run
  fi
}

stop_native_services() {
  # 通过系统服务管理器停止
  case "$(uname -s)" in
    Darwin)
      if command -v launchctl >/dev/null 2>&1; then
        launchctl unload "${HOME}/Library/LaunchAgents/com.easygate.native-traefik.plist" >/dev/null 2>&1 || true
        launchctl unload "${HOME}/Library/LaunchAgents/com.easygate.native-cloudflared.plist" >/dev/null 2>&1 || true
      fi
      ;;
    Linux)
      if command -v systemctl >/dev/null 2>&1; then
        systemctl --user stop "easygate-traefik.service" "easygate-cloudflared.service" >/dev/null 2>&1 || true
        systemctl --user reset-failed "easygate-traefik.service" "easygate-cloudflared.service" >/dev/null 2>&1 || true
      fi
      ;;
  esac

  # 同时通过 PID 文件终止所有 nohup 进程（兜底）
  for pid_file in \
    "${EASYGATE_HOME}/run/native-cloudflared.pid" \
    "${EASYGATE_HOME}/run/native-traefik.pid" \
    "${EASYGATE_HOME}/run/native-demo-api.pid" \
    "${EASYGATE_HOME}/run/native-demo-test-api.pid"; do
    stop_pid_file "$pid_file"
  done
}

# 原生模式 demo 进程管理
start_native_demo() {
  local env_file="${EASYGATE_HOME}/native/.env"
  [[ -f "$env_file" ]] || { error "未找到原生模式环境文件：${env_file}"; return 1; }
  # shellcheck source=/dev/null
  source "$env_file"
  local python_bin
  python_bin="$(find_python)" || { error "原生 demo 需要 python3 或 python"; return 1; }
  local api_port="${EASYGATE_NATIVE_API_PORT:-19080}"
  local test_api_port="${EASYGATE_NATIVE_TEST_API_PORT:-19081}"
  write_native_demo_server
  start_process "native-demo-api" "$python_bin" "${EASYGATE_HOME}/lib/native-demo-server.py" --port "$api_port"
  start_process "native-demo-test-api" "$python_bin" "${EASYGATE_HOME}/lib/native-demo-server.py" --port "$test_api_port"
  info "原生 demo 服务已启动"
}

stop_native_demo() {
  stop_pid_file "${EASYGATE_HOME}/run/native-demo-api.pid"
  stop_pid_file "${EASYGATE_HOME}/run/native-demo-test-api.pid"
  info "原生 demo 服务已停止"
}

# 注销系统服务（停止进程 + 删除注册文件 + 清理 PID）
unregister_native_services() {
  case "$(uname -s)" in
    Linux)
      systemctl --user stop "easygate-traefik.service" "easygate-cloudflared.service" "easygate-logrotate.timer" >/dev/null 2>&1 || true
      systemctl --user disable "easygate-traefik.service" "easygate-cloudflared.service" "easygate-logrotate.timer" >/dev/null 2>&1 || true
      rm -f "${HOME}/.config/systemd/user/easygate-traefik.service" \
            "${HOME}/.config/systemd/user/easygate-cloudflared.service" \
            "${HOME}/.config/systemd/user/easygate-logrotate.service" \
            "${HOME}/.config/systemd/user/easygate-logrotate.timer"
      systemctl --user daemon-reload >/dev/null 2>&1 || true
      ;;
    Darwin)
      launchctl unload "${HOME}/Library/LaunchAgents/com.easygate.native-traefik.plist" >/dev/null 2>&1 || true
      launchctl unload "${HOME}/Library/LaunchAgents/com.easygate.native-cloudflared.plist" >/dev/null 2>&1 || true
      launchctl unload "${HOME}/Library/LaunchAgents/com.easygate.logrotate.plist" >/dev/null 2>&1 || true
      rm -f "${HOME}/Library/LaunchAgents/com.easygate.native-traefik.plist" \
            "${HOME}/Library/LaunchAgents/com.easygate.native-cloudflared.plist" \
            "${HOME}/Library/LaunchAgents/com.easygate.logrotate.plist"
      ;;
  esac
  rm -f "${EASYGATE_HOME}/run/native-traefik.pid" \
        "${EASYGATE_HOME}/run/native-cloudflared.pid" \
        "${EASYGATE_HOME}/run/native-demo-api.pid" \
        "${EASYGATE_HOME}/run/native-demo-test-api.pid"
}


_service_yaml_path() {
  local mode
  mode="$(detect_mode)" 2>/dev/null || true
  case "$mode" in
    compose) printf '%s/traefik/dynamic/localhost-services.yml' "$EASYGATE_HOME" ;;
    native)  printf '%s/native/dynamic/services.yml' "$EASYGATE_HOME" ;;
    *) printf '%s/native/dynamic/services.yml' "$EASYGATE_HOME"; return 0 ;;
  esac
}

service_add() {
  install_service_helper 2>/dev/null || true
  local name="" host="" url=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) shift; name="${1:-}" ;;
      --host) shift; host="${1:-}" ;;
      --url) shift; url="${1:-}" ;;
      *) error "未知参数：$1"; return 1 ;;
    esac
    shift
  done
  [[ -z "$name" ]] && { error "缺少 --name（服务名称）"; return 1; }
  [[ -z "$host" ]] && { error "缺少 --host（访问域名，如 app.example.com）"; return 1; }
  [[ -z "$url" ]] && { error "缺少 --url（上游地址，如 http://192.168.1.100:8080）"; return 1; }

  local yaml_file helper
  yaml_file="$(_service_yaml_path)" || return 1
  mkdir -p "$(dirname "$yaml_file")"
  helper="$(_service_helper)" || { error "service-helper.py 不可用"; return 1; }
  python3 "$helper" add "$yaml_file" "$name" "$host" "$url"
}

service_remove() {
  install_service_helper 2>/dev/null || true
  local name="${1:-}"
  [[ -z "$name" ]] && { error "用法：easygate service remove <name>"; return 1; }
  local yaml_file helper
  yaml_file="$(_service_yaml_path)" || return 1
  [[ ! -f "$yaml_file" ]] && { warn "服务配置文件不存在：${yaml_file}"; return 0; }
  helper="$(_service_helper)" || { error "service-helper.py 不可用"; return 1; }
  python3 "$helper" remove "$yaml_file" "$name"
}

service_list() {
  install_service_helper 2>/dev/null || true
  local yaml_file helper
  yaml_file="$(_service_yaml_path)" 2>/dev/null || yaml_file=""
  if [[ -z "$yaml_file" || ! -f "$yaml_file" ]]; then
    info "暂无已配置的服务"
    return 0
  fi
  helper="$(_service_helper)" || { error "service-helper.py 不可用"; return 1; }
  python3 "$helper" list "$yaml_file"
}


show_status() {
  local mode
  mode="$(detect_mode)"
  case "$mode" in
    compose) compose ps "$@" ;;
    native)
      info "原生模式进程状态："
      local showed_system=false
      # 查询系统服务管理器（traefik + cloudflared）
      case "$(uname -s)" in
        Darwin)
          if command -v launchctl >/dev/null 2>&1; then
            showed_system=true
            for svc in native-traefik native-cloudflared; do
              local label="com.easygate.${svc}"
              local pid
              pid="$(launchctl list 2>/dev/null | awk -v l="$label" '$3==l {print $1}')" || true
              local name="${svc#native-}"
              if [[ -n "$pid" && "$pid" != "-" ]]; then
                printf '  %-15s running  (pid %s)\n' "$name" "$pid"
              else
                printf '  %-15s stopped\n' "$name"
              fi
            done
          fi
          ;;
        Linux)
          if command -v systemctl >/dev/null 2>&1; then
            showed_system=true
            for svc in easygate-traefik easygate-cloudflared; do
              local active
              active="$(systemctl --user is-active "${svc}.service" 2>/dev/null)" || true
              local name="${svc#easygate-}"
              if [[ "$active" == "active" ]]; then
                printf '  %-15s running\n' "$name"
              else
                printf '  %-15s stopped\n' "$name"
              fi
            done
          fi
          ;;
      esac
      # 系统服务不可用时，fallback PID 文件查 traefik/cloudflared
      if [[ "$showed_system" != true ]]; then
        for pid_file in \
          "${EASYGATE_HOME}/run/native-traefik.pid" \
          "${EASYGATE_HOME}/run/native-cloudflared.pid"; do
          local name
          name="$(basename "$pid_file" .pid | sed 's/^native-//')"
          if native_pid_active "$pid_file"; then
            printf '  %-15s running  (pid %s)\n' "$name" "$(cat "$pid_file")"
          else
            printf '  %-15s stopped\n' "$name"
          fi
        done
      fi
      # demo 服务始终通过 PID 文件检查（nohup 管理，无系统服务）
      for pid_file in \
        "${EASYGATE_HOME}/run/native-demo-api.pid" \
        "${EASYGATE_HOME}/run/native-demo-test-api.pid"; do
        local name
        name="$(basename "$pid_file" .pid | sed 's/^native-//')"
        if native_pid_active "$pid_file"; then
          printf '  %-15s running  (pid %s)\n' "$name" "$(cat "$pid_file")"
        else
          printf '  %-15s stopped\n' "$name"
        fi
      done
      ;;
    *) error "未找到已部署的服务"; return 1 ;;
  esac
}

cmd="${1:-}"
if [[ $# -gt 0 ]]; then shift; fi

case "$cmd" in
  deploy)
    native_mode=false; deploy_args=()
    for arg in "$@"; do
      if [[ "$arg" == "--native" ]]; then native_mode=true
      else deploy_args+=("$arg"); fi
    done
    if [[ "$native_mode" == true ]]; then deploy_native "${deploy_args[@]}"
    else deploy_compose "${deploy_args[@]}"; fi
    ;;
  start) start_services "$@" ;;
  stop) stop_services "$@" ;;
  restart) restart_services "$@" ;;
  ps|status) show_status "$@" ;;
  logs)
    # --rotate: 仅执行日志轮转
    if [[ "${1:-}" == "--rotate" ]]; then
      rotate_logs
      exit 0
    fi
    # 查看前先检查是否需要轮转
    rotate_logs
    mode="$(detect_mode)"
    case "$mode" in
      compose) compose logs -f traefik cloudflared "$@" ;;
      native)
        tail -f "${EASYGATE_HOME}/logs/native-traefik.log" "${EASYGATE_HOME}/logs/native-cloudflared.log" "$@"
        ;;
      *) error "未找到已部署的服务，请先执行 easygate deploy" ; exit 1 ;;
    esac
    ;;
  config)
    mode="$(detect_mode)"
    case "$mode" in
      compose) compose config "$@" ;;
      native)
        info "=== Traefik 配置 ==="
        cat "${EASYGATE_HOME}/native/traefik.yml" 2>/dev/null || error "未找到 Traefik 配置"
        if [[ -f "${EASYGATE_HOME}/cloudflared/config.native.yml" ]]; then
          echo ""
          info "=== Cloudflared 配置 ==="
          cat "${EASYGATE_HOME}/cloudflared/config.native.yml"
        fi
        ;;
      *) error "未找到已部署的服务，请先执行 easygate deploy" ; exit 1 ;;
    esac
    ;;
  demo)
    mode="$(detect_mode)"
    subcmd="${1:-start}"
    [[ "${1:-}" != "" ]] && shift || true
    case "$mode" in
      compose)
        case "$subcmd" in
          start) compose --profile demo up -d "$@" ;;
          stop)
            compose --profile demo stop demo-api demo-test-api "$@"
            compose --profile demo rm -f demo-api demo-test-api "$@"
            ;;
          restart)
            compose --profile demo stop demo-api demo-test-api "$@"
            compose --profile demo rm -f demo-api demo-test-api "$@"
            compose --profile demo up -d "$@"
            ;;
          *) error "未知 demo 子命令：${subcmd}。可用：start|stop|restart"; usage; exit 1 ;;
        esac
        ;;
      native)
        case "$subcmd" in
          start|restart) start_native_demo ;;
          stop) stop_native_demo ;;
          *) error "未知 demo 子命令：${subcmd}。可用：start|stop|restart"; usage; exit 1 ;;
        esac
        ;;
      *) error "未找到已部署的服务，请先执行 easygate deploy" ; exit 1 ;;
    esac
    ;;
  service)
    subcmd="${1:-}"
    [[ "${1:-}" != "" ]] && shift || true
    case "$subcmd" in
      add|remove|list) service_"$subcmd" "$@" ;;
      *) error "未知 service 子命令：${subcmd}。可用：add|remove|list"; usage; exit 1 ;;
    esac
    ;;
  home) printf '%s\n' "$EASYGATE_HOME" ;;
  version|--version) printf 'easygate %s\n' "$VERSION" ;;
  uninstall)
    # 停止所有服务（compose + native + nohup 进程）
    stop_services 2>/dev/null || true
    # 显式清理 demo 服务（nohup 进程）
    stop_native_demo 2>/dev/null || true
    # 停掉所有可能的 nohup 进程（兜底，防止 PID 文件残留）
    for pid_file in \
      "${EASYGATE_HOME}/run/native-cloudflared.pid" \
      "${EASYGATE_HOME}/run/native-traefik.pid" \
      "${EASYGATE_HOME}/run/native-demo-api.pid" \
      "${EASYGATE_HOME}/run/native-demo-test-api.pid"; do
      stop_pid_file "$pid_file"
    done
    # 兜底：kill 残留的 demo Python 进程
    pkill -f "native-demo-server.py" 2>/dev/null || true
    # 停掉 compose 容器（含 demo profile，确保 demo 容器也清理）
    if command -v docker >/dev/null 2>&1 && [[ -f "$COMPOSE_FILE" ]]; then
      compose --profile demo down --remove-orphans >/dev/null 2>&1 || true
    fi
    # 注销并清理系统服务
    unregister_native_services 2>/dev/null || true
    for rc in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile"; do
      [[ -f "$rc" ]] || continue
      if grep -qs "${EASYGATE_HOME}/bin" "$rc" 2>/dev/null; then
        if [[ "$(uname -s)" == "Darwin" ]]; then
          sed -i '' '/^# EasyGate CLI$/,/^export PATH=.*easygate.*bin.*$/d' "$rc" 2>/dev/null || true
          sed -i '' '/export PATH=.*easygate.*bin.*PATH/d' "$rc" 2>/dev/null || true
        else
          sed -i '/^# EasyGate CLI$/,/^export PATH=.*easygate.*bin.*$/d' "$rc" 2>/dev/null || true
          sed -i '/export PATH=.*easygate.*bin.*PATH/d' "$rc" 2>/dev/null || true
        fi
        info "已从 ${rc} 移除 EasyGate PATH 配置"
      fi
    done
    if [[ -e "$EASYGATE_HOME" ]]; then
      rm -rf "$EASYGATE_HOME"
      info "已删除运行时目录 ${EASYGATE_HOME}"
    fi
    info "卸载完成。Cloudflare 侧资源如需删除，请使用 cloudflared CLI 或 Cloudflare Dashboard 手动处理。"
    ;;
  -h|--help|"") usage ;;
  *) error "未知命令：$cmd"; usage; exit 1 ;;
esac
