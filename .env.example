BASE_DOMAIN=example.com

# Traefik 暴露到宿主机的本地调试端口。
# 公网流量通过 Cloudflare Tunnel 进入，不依赖这个端口。
TRAEFIK_HTTP_PORT=18080

# Traefik dashboard 的访问域名。建议只在可信网络中使用。
TRAEFIK_DASHBOARD_HOST=traefik.example.com

# 原生模式 demo 服务端口。仅 deploy-native --demo / local-acceptance-native 使用。
EASYGATE_NATIVE_API_PORT=19080
EASYGATE_NATIVE_TEST_API_PORT=19081
