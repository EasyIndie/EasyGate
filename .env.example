BASE_DOMAIN=example.com

# 在 Cloudflare Zero Trust > Networks > Tunnels 中创建。
# 使用 remotely managed tunnel，然后添加 public hostname：
#   *.example.com -> http://traefik:80
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

# 可选：用 Cloudflare Access 保护 Traefik dashboard，
# 并只通过 https://traefik.example.com 访问。
TRAEFIK_DASHBOARD_HOST=traefik.example.com
